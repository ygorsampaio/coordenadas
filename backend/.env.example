# Database
# Use a URI fornecida pelo MongoDB Atlas (mongodb:// ou mongodb+srv://)
# Para replicas sets em Atlas, use mongodb:// com as 3 URLs dos shards
MONGODB_URI=mongodb://usuario:senha@host1:27017,host2:27017,host3:27017/?ssl=true&replicaSet=atlas-xxx&authSource=admin&appName=1

# Server
PORT=3000
NODE_ENV=development
